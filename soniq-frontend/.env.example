# Backend API (leave blank to run in live-FFT-only mode without backend)
VITE_API_URL=http://127.0.0.1:8000
VITE_WS_URL=ws://127.0.0.1:8000

# Spotify OAuth (optional — for Spotify streaming integration)
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback/spotify
