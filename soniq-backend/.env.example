APP_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-generate-with-secrets-token-urlsafe-48

CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://soniq:soniq@localhost:5432/soniq
REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads
AWS_BUCKET_NAME=soniq-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback/spotify

DEMUCS_MODEL=htdemucs
DEMUCS_DEVICE=cpu
MAX_AUDIO_DURATION=600
MAX_FILE_SIZE_MB=50
FRAME_DURATION_MS=50
